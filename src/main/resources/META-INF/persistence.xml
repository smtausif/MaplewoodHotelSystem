<?xml version="1.0" encoding="UTF-8"?>
<!--
    JPA / Hibernate configuration for the Maplewood Grand hotel system (Data tier).

    Persistence unit "maplewoodPU" wires our JPA entities to an embedded, file-based
    H2 database. The EntityManagerFactory built from this unit is created ONCE and
    treated as a singleton (see JpaUtil) as required by the project spec.
-->
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
                                 https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="maplewoodPU" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <!-- All JPA entities in the model package. Listed explicitly so entity
             discovery works reliably under the Java module system (JPMS). -->
        <class>ca.senecacollege.hotelreservation.hotelreservation.model.Guest</class>
        <class>ca.senecacollege.hotelreservation.hotelreservation.model.RoomTypeEntity</class>
        <class>ca.senecacollege.hotelreservation.hotelreservation.model.Room</class>
        <class>ca.senecacollege.hotelreservation.hotelreservation.model.Reservation</class>
        <class>ca.senecacollege.hotelreservation.hotelreservation.model.ReservationRoom</class>
        <class>ca.senecacollege.hotelreservation.hotelreservation.model.Addon</class>
        <class>ca.senecacollege.hotelreservation.hotelreservation.model.ReservationAddon</class>
        <class>ca.senecacollege.hotelreservation.hotelreservation.model.Billing</class>
        <class>ca.senecacollege.hotelreservation.hotelreservation.model.Payment</class>
        <class>ca.senecacollege.hotelreservation.hotelreservation.model.Discount</class>
        <class>ca.senecacollege.hotelreservation.hotelreservation.model.LoyaltyAccount</class>
        <class>ca.senecacollege.hotelreservation.hotelreservation.model.LoyaltyTransaction</class>
        <class>ca.senecacollege.hotelreservation.hotelreservation.model.Waitlist</class>
        <class>ca.senecacollege.hotelreservation.hotelreservation.model.Feedback</class>
        <class>ca.senecacollege.hotelreservation.hotelreservation.model.AdminUser</class>
        <class>ca.senecacollege.hotelreservation.hotelreservation.model.AuditLog</class>

        <!-- Only entities annotated with @Entity are managed. -->
        <exclude-unlisted-classes>true</exclude-unlisted-classes>

        <properties>
            <!-- ===== Connection (embedded, file-based H2) =====
                 AUTO_SERVER=TRUE lets several JVMs share the same file, which we
                 need later for the optional multi-admin server requirement. -->
            <property name="jakarta.persistence.jdbc.driver" value="org.h2.Driver"/>
            <property name="jakarta.persistence.jdbc.url"
                      value="jdbc:h2:file:./data/maplewood;AUTO_SERVER=TRUE;DB_CLOSE_DELAY=-1"/>
            <property name="jakarta.persistence.jdbc.user" value="sa"/>
            <property name="jakarta.persistence.jdbc.password" value=""/>

            <!-- ===== Hibernate ===== -->
            <property name="hibernate.dialect" value="org.hibernate.dialect.H2Dialect"/>
            <!-- update: keep data between runs, evolve the schema as entities change -->
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <!-- Educational: print the SQL Hibernate generates -->
            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>
            <property name="hibernate.highlight_sql" value="true"/>
        </properties>
    </persistence-unit>
</persistence>
