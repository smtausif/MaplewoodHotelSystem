<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane fx:id="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="ca.senecacollege.hotelreservation.hotelreservation.AdminLoyaltyPage"
           prefWidth="1024" prefHeight="768"
           styleClass="root-pane" stylesheets="@kiosk.css">

    <ImageView fitWidth="1024" fitHeight="768" preserveRatio="false" opacity="0.12">
        <image>
            <Image url="@/lobby-background.jpg"/>
        </image>
    </ImageView>

    <Region styleClass="cream-overlay"/>

    <VBox spacing="12">
        <padding>
            <Insets top="20" right="30" bottom="18" left="30"/>
        </padding>

        <HBox alignment="CENTER_LEFT" spacing="12">
            <VBox spacing="2">
                <Label text="Loyalty Program" styleClass="dashboard-title"/>
                <Label text="R E W A R D S   &amp; R E D E M P T I O N" styleClass="portal-sub"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <VBox alignment="CENTER_RIGHT" spacing="4">
                <Label fx:id="loggedInLabel" styleClass="note-label"/>
                <HBox spacing="8" alignment="CENTER_RIGHT">
                    <Button text="Back to Dashboard" onAction="#onBack" styleClass="back-nav-button-small"/>
                    <Button text="Redeem Points" onAction="#onRedeem" styleClass="save-button"/>
                </HBox>
            </VBox>
        </HBox>

        <HBox styleClass="res-banner" alignment="CENTER_LEFT">
            <padding>
                <Insets top="12" right="18" bottom="12" left="18"/>
            </padding>
            <Label fx:id="memberLabel" styleClass="banner-text"/>
        </HBox>

        <HBox spacing="14">
            <VBox styleClass="stat-chip" alignment="CENTER" prefWidth="200">
                <Label text="POINTS BALANCE" styleClass="stat-title"/>
                <Label fx:id="balanceValue" styleClass="stat-value"/>
            </VBox>
            <VBox styleClass="stat-chip" alignment="CENTER" prefWidth="200">
                <Label text="LIFETIME EARNED" styleClass="stat-title"/>
                <Label fx:id="earnedValue" styleClass="stat-value"/>
            </VBox>
            <VBox styleClass="stat-chip" alignment="CENTER" prefWidth="200">
                <Label text="REDEEMED" styleClass="stat-title"/>
                <Label fx:id="redeemedValue" styleClass="stat-value"/>
            </VBox>
            <VBox styleClass="stat-chip" alignment="CENTER" prefWidth="230">
                <Label text="EARN RATE" styleClass="stat-title"/>
                <Label fx:id="rateValue" styleClass="stat-value"/>
            </VBox>
        </HBox>

        <Label text="E A R N I N G   &amp; R E D E M P T I O N   H I S T O R Y" styleClass="section-label"/>
        <TableView fx:id="table" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="dateCol" text="Date" prefWidth="120"/>
                <TableColumn fx:id="typeCol" text="Type" prefWidth="130"/>
                <TableColumn fx:id="resCol" text="Reservation" prefWidth="160"/>
                <TableColumn fx:id="pointsCol" text="Points" prefWidth="140"/>
                <TableColumn fx:id="valueCol" text="Value" prefWidth="150"/>
                <TableColumn fx:id="byCol" text="By" prefWidth="150"/>
            </columns>
        </TableView>

        <Label text="Redemption is capped per reservation; discounts are applied before loyalty redemption."
               styleClass="note-label"/>
    </VBox>
</StackPane>