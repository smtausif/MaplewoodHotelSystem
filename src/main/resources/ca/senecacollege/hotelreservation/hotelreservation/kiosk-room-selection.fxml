<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<StackPane fx:id="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="ca.senecacollege.hotelreservation.hotelreservation.RoomSelectionPage"
           prefWidth="1024" prefHeight="768"
           styleClass="root-pane" stylesheets="@kiosk.css">

    <Region styleClass="cream-overlay"/>

    <VBox alignment="TOP_CENTER" spacing="10">
        <padding>
            <Insets top="18" right="36" bottom="16" left="36"/>
        </padding>

        <!-- ============ HEADER ============ -->
        <StackPane>
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Button onAction="#onRulesClicked" styleClass="rules-button"
                        text="RULES &amp; REGULATIONS" contentDisplay="LEFT" graphicTextGap="10">
                    <graphic>
                        <SVGPath content="M14,2 H6 C4.9,2 4,2.9 4,4 v16 c0,1.1 0.9,2 2,2 h12 c1.1,0 2,-0.9 2,-2 V8 L14,2 z M16,18 H8 v-2 h8 V18 z M16,14 H8 v-2 h8 V14 z M13,9 V3.5 L18.5,9 H13 z"
                                 scaleX="0.8" scaleY="0.8" styleClass="gold-icon"/>
                    </graphic>
                </Button>

                <Region HBox.hgrow="ALWAYS"/>

                <VBox alignment="TOP_RIGHT">
                    <Label fx:id="clockLabel" text="10:48 AM" styleClass="clock-label"/>
                    <Label fx:id="dateLabel" text="Saturday, July 4" styleClass="date-label"/>
                </VBox>
            </HBox>

            <VBox alignment="CENTER" pickOnBounds="false" mouseTransparent="true">
                <Label text="Maplewood Grand" styleClass="header-hotel-name"/>
                <Label text="H O T E L" styleClass="header-hotel-sub"/>
            </VBox>
        </StackPane>

        <!-- ============ TITLE ============ -->
        <Label text="SELECT YOUR ROOMS" styleClass="page-title"/>
        <Label text="Step 4 of 7 — choose one or more room types and set a quantity for each" styleClass="step-label"/>

        <!-- ============ ROOM CARDS ============ -->
        <HBox alignment="CENTER" spacing="16">

            <VBox fx:id="doubleCard" styleClass="room-card" prefWidth="220" spacing="6" alignment="TOP_CENTER">
                <ImageView fitWidth="192" fitHeight="110" preserveRatio="false">
                    <image>
                        <Image url="@/double_room.jpg"/>
                    </image>
                </ImageView>
                <Label text="Double Room" styleClass="room-name"/>
                <Label text="Ideal for families or groups, featuring two queen beds. Sleeps up to 4 people."
                       styleClass="room-desc" wrapText="true" maxWidth="190" textAlignment="CENTER"/>
                <Region VBox.vgrow="ALWAYS"/>
                <HBox alignment="CENTER" spacing="4">
                    <Label fx:id="doublePrice" styleClass="price-label"/>
                    <Label text="/ night" styleClass="price-suffix"/>
                </HBox>
                <HBox alignment="CENTER" spacing="10">
                    <Button text="−" onAction="#doubleMinus" styleClass="stepper-btn"/>
                    <Label fx:id="doubleQty" text="0" styleClass="count-label"/>
                    <Button text="+" onAction="#doublePlus" styleClass="stepper-btn"/>
                </HBox>
            </VBox>

            <VBox fx:id="singleCard" styleClass="room-card" prefWidth="220" spacing="6" alignment="TOP_CENTER">
                <ImageView fitWidth="192" fitHeight="110" preserveRatio="false">
                    <image>
                        <Image url="@/single_room.jpg"/>
                    </image>
                </ImageView>
                <Label text="Single Room" styleClass="room-name"/>
                <Label text="Comfortable and efficient for individuals or couples. Sleeps up to 2 people."
                       styleClass="room-desc" wrapText="true" maxWidth="190" textAlignment="CENTER"/>
                <Region VBox.vgrow="ALWAYS"/>
                <HBox alignment="CENTER" spacing="4">
                    <Label fx:id="singlePrice" styleClass="price-label"/>
                    <Label text="/ night" styleClass="price-suffix"/>
                </HBox>
                <HBox alignment="CENTER" spacing="10">
                    <Button text="−" onAction="#singleMinus" styleClass="stepper-btn"/>
                    <Label fx:id="singleQty" text="0" styleClass="count-label"/>
                    <Button text="+" onAction="#singlePlus" styleClass="stepper-btn"/>
                </HBox>
            </VBox>

            <VBox fx:id="deluxeCard" styleClass="room-card" prefWidth="220" spacing="6" alignment="TOP_CENTER">
                <ImageView fitWidth="192" fitHeight="110" preserveRatio="false">
                    <image>
                        <Image url="@/delux-room.jpg"/>
                    </image>
                </ImageView>
                <Label text="Deluxe Room" styleClass="room-name"/>
                <Label text="Spacious and well-appointed for a luxurious stay. Sleeps up to 2 people."
                       styleClass="room-desc" wrapText="true" maxWidth="190" textAlignment="CENTER"/>
                <Region VBox.vgrow="ALWAYS"/>
                <HBox alignment="CENTER" spacing="4">
                    <Label fx:id="deluxePrice" styleClass="price-label"/>
                    <Label text="/ night" styleClass="price-suffix"/>
                </HBox>
                <HBox alignment="CENTER" spacing="10">
                    <Button text="−" onAction="#deluxeMinus" styleClass="stepper-btn"/>
                    <Label fx:id="deluxeQty" text="0" styleClass="count-label"/>
                    <Button text="+" onAction="#deluxePlus" styleClass="stepper-btn"/>
                </HBox>
            </VBox>

            <VBox fx:id="penthouseCard" styleClass="room-card" prefWidth="220" spacing="6" alignment="TOP_CENTER">
                <ImageView fitWidth="192" fitHeight="110" preserveRatio="false">
                    <image>
                        <Image url="@/pent_house.jpg"/>
                    </image>
                </ImageView>
                <Label text="Penthouse Suite" styleClass="room-name"/>
                <Label text="Our premier accommodation with stunning views and premium amenities. Sleeps up to 2 people."
                       styleClass="room-desc" wrapText="true" maxWidth="190" textAlignment="CENTER"/>
                <Region VBox.vgrow="ALWAYS"/>
                <HBox alignment="CENTER" spacing="4">
                    <Label fx:id="penthousePrice" styleClass="price-label"/>
                    <Label text="/ night" styleClass="price-suffix"/>
                </HBox>
                <HBox alignment="CENTER" spacing="10">
                    <Button text="−" onAction="#penthouseMinus" styleClass="stepper-btn"/>
                    <Label fx:id="penthouseQty" text="0" styleClass="count-label"/>
                    <Button text="+" onAction="#penthousePlus" styleClass="stepper-btn"/>
                </HBox>
            </VBox>
        </HBox>

        <!-- ============ RESERVATION SUMMARY ============ -->
        <VBox styleClass="panel-card" maxWidth="936" spacing="10">
            <padding>
                <Insets top="14" right="20" bottom="14" left="20"/>
            </padding>

            <Label text="RESERVATION SUMMARY" styleClass="card-title"/>

            <TableView fx:id="summaryTable" prefHeight="140" maxHeight="140">
                <columns>
                    <TableColumn fx:id="typeCol" text="Room Type" prefWidth="300"/>
                    <TableColumn fx:id="qtyCol" text="Quantity" prefWidth="150"/>
                    <TableColumn fx:id="rateCol" text="Price / Night" prefWidth="190"/>
                    <TableColumn fx:id="subtotalCol" text="Subtotal" prefWidth="190"/>
                </columns>
                <placeholder>
                    <Label text="No rooms selected yet — use the + / − buttons above to add some."
                           styleClass="row-sublabel"/>
                </placeholder>
            </TableView>

            <HBox alignment="CENTER_LEFT" spacing="14">
                <VBox styleClass="stat-chip" alignment="CENTER" prefWidth="170">
                    <Label text="TOTAL ROOMS" styleClass="stat-title"/>
                    <Label fx:id="totalRoomsValue" text="0" styleClass="stat-value"/>
                </VBox>
                <VBox styleClass="stat-chip" alignment="CENTER" prefWidth="200">
                    <Label text="TOTAL PRICE" styleClass="stat-title"/>
                    <Label fx:id="totalPriceValue" text="0.00" styleClass="stat-value"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Availability will be confirmed at the next step." styleClass="note-label" wrapText="true"/>
            </HBox>
        </VBox>

        <!-- ============ BACK / NEXT ============ -->
        <HBox alignment="CENTER" maxWidth="936">
            <Button text="BACK" onAction="#onBack" styleClass="back-nav-button"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="NEXT: ADD-ONS" onAction="#onNext" styleClass="next-button"/>
        </HBox>
    </VBox>
</StackPane>
