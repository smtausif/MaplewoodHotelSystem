<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane fx:id="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="ca.senecacollege.hotelreservation.hotelreservation.AdminDashboardPage"
           prefWidth="1024" prefHeight="768"
           styleClass="root-pane" stylesheets="@kiosk.css">

    <VBox spacing="12">
        <padding>
            <Insets top="22" right="30" bottom="20" left="30"/>
        </padding>

        <!-- ============ TITLE BAR ============ -->
        <HBox alignment="CENTER_LEFT" spacing="16">
            <Label text="Reservations Dashboard" styleClass="dashboard-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <VBox alignment="CENTER_RIGHT" spacing="4">
                <Label fx:id="loggedInLabel" styleClass="note-label"/>
                <Button text="Logout" onAction="#onLogout" styleClass="back-nav-button-small"/>
            </VBox>
        </HBox>

        <!-- ============ SEARCH ROW ============ -->
        <HBox alignment="CENTER_LEFT" spacing="10">
            <TextField fx:id="searchField" promptText="Search" prefWidth="380"
                       styleClass="form-field" onAction="#applyFilters"/>
            <Button text="Search" onAction="#applyFilters" styleClass="back-nav-button-small"/>
        </HBox>

        <!-- ============ FILTER ROW ============ -->
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label text="Status" styleClass="filter-label"/>
            <ComboBox fx:id="statusCombo" prefWidth="150"/>
            <Label text="Room type" styleClass="filter-label">
                <HBox.margin>
                    <Insets left="14"/>
                </HBox.margin>
            </Label>
            <ComboBox fx:id="roomCombo" prefWidth="150"/>
            <DatePicker fx:id="fromDate" promptText="From" prefWidth="150" editable="false">
                <HBox.margin>
                    <Insets left="14"/>
                </HBox.margin>
            </DatePicker>
            <Label text="to" styleClass="filter-label"/>
            <DatePicker fx:id="toDate" promptText="To" prefWidth="150" editable="false"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="New Reservation" onAction="#onNewReservation" styleClass="menu-btn"/>
            <Button text="Waitlist" onAction="#onOpenWaitlist" styleClass="menu-btn"/>
            <Button text="Reports" onAction="#onOpenReports" styleClass="menu-btn"/>
        </HBox>

        <!-- ============ TABLE ============ -->
        <TableView fx:id="table" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="resCol" text="Res #" prefWidth="100"/>
                <TableColumn fx:id="guestCol" text="Guest" prefWidth="165"/>
                <TableColumn fx:id="phoneCol" text="Phone" prefWidth="145"/>
                <TableColumn fx:id="checkinCol" text="Check-in" prefWidth="115"/>
                <TableColumn fx:id="nightsCol" text="Nights" prefWidth="75"/>
                <TableColumn fx:id="roomsCol" text="Rooms" prefWidth="125"/>
                <TableColumn fx:id="statusCol" text="Status" prefWidth="115"/>
                <TableColumn fx:id="balanceCol" text="Balance" prefWidth="110"/>
            </columns>
        </TableView>

        <!-- ============ PAGINATION FOOTER ============ -->
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label fx:id="showingLabel" styleClass="filter-label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="prevButton" text="Previous" onAction="#onPrevPage" styleClass="back-nav-button-small"/>
            <Label fx:id="pageLabel" styleClass="pager-label"/>
            <Button fx:id="nextButton" text="Next" onAction="#onNextPage" styleClass="back-nav-button-small"/>
        </HBox>
    </VBox>
</StackPane>