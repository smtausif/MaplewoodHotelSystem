<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<StackPane fx:id="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="ca.senecacollege.hotelreservation.hotelreservation.ConfirmationPage"
           prefWidth="1024" prefHeight="768"
           styleClass="root-pane" stylesheets="@kiosk.css">

    <Region styleClass="cream-overlay"/>

    <VBox alignment="TOP_CENTER" spacing="12">
        <padding>
            <Insets top="20" right="36" bottom="18" left="36"/>
        </padding>

        <!-- ============ HEADER ============ -->
        <StackPane>
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Button onAction="#onRulesClicked" styleClass="rules-button"
                        text="RULES &amp; REGULATIONS" contentDisplay="LEFT" graphicTextGap="10">
                    <graphic>
                        <SVGPath content="M14,2 H6 C4.9,2 4,2.9 4,4 v16 c0,1.1 0.9,2 2,2 h12 c1.1,0 2,-0.9 2,-2 V8 L14,2 z M16,18 H8 v-2 h8 V18 z M16,14 H8 v-2 h8 V14 z M13,9 V3.5 L18.5,9 H13 z"
                                 scaleX="0.8" scaleY="0.8" styleClass="gold-icon"/>
                    </graphic>
                </Button>

                <Region HBox.hgrow="ALWAYS"/>

                <VBox alignment="TOP_RIGHT">
                    <Label fx:id="clockLabel" text="10:49 AM" styleClass="clock-label"/>
                    <Label fx:id="dateLabel" text="Saturday, July 4" styleClass="date-label"/>
                </VBox>
            </HBox>

            <VBox alignment="CENTER" pickOnBounds="false" mouseTransparent="true">
                <Label text="Maplewood Grand" styleClass="header-hotel-name"/>
                <Label text="H O T E L" styleClass="header-hotel-sub"/>
            </VBox>
        </StackPane>

        <!-- ============ TITLE ============ -->
        <Label fx:id="thankYouLabel" text="Thank you!" styleClass="thankyou-title"/>

        <!-- ============ CONFIRMATION CARD ============ -->
        <VBox styleClass="panel-card" maxWidth="936" spacing="18" alignment="TOP_CENTER" VBox.vgrow="ALWAYS">
            <padding>
                <Insets top="28" right="28" bottom="24" left="28"/>
            </padding>

            <Label fx:id="bookedLineLabel" styleClass="confirm-line"/>
            <Label fx:id="codeLineLabel" styleClass="confirm-code"/>
            <Label text="Billing will be handled at the front desk on arrival." styleClass="confirm-line"/>
            <Label text="Please bring your confirmation code and a photo ID." styleClass="confirm-line"/>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- big gold checkmark -->
            <SVGPath content="M9,16.17 L4.83,12 L3.41,13.41 L9,19 L21,7 L19.59,5.59 Z"
                     scaleX="6" scaleY="6" styleClass="big-check">
                <VBox.margin>
                    <Insets top="30" bottom="50"/>
                </VBox.margin>
            </SVGPath>

            <Region VBox.vgrow="ALWAYS"/>
        </VBox>

        <!-- ============ BUTTONS ============ -->
        <HBox alignment="CENTER" spacing="60" maxWidth="936">
            <VBox.margin>
                <Insets top="8"/>
            </VBox.margin>
            <Button text="Email me a copy" onAction="#onEmailCopy" styleClass="secondary-button" prefWidth="380"/>
            <Button text="Done" onAction="#onDone" styleClass="next-button" prefWidth="380"/>
        </HBox>
    </VBox>
</StackPane>