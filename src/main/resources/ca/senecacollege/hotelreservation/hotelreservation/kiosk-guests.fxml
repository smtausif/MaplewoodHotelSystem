<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<StackPane fx:id="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="ca.senecacollege.hotelreservation.hotelreservation.GuestsPage"
           prefWidth="1024" prefHeight="768"
           styleClass="root-pane" stylesheets="@kiosk.css">

    <Region styleClass="cream-overlay"/>

    <VBox alignment="TOP_CENTER" spacing="16">
        <padding>
            <Insets top="24" right="40" bottom="20" left="40"/>
        </padding>

        <!-- ============ HEADER ============ -->
        <StackPane>
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Button onAction="#onBack" styleClass="rules-button"
                        text="BACK" contentDisplay="LEFT" graphicTextGap="8">
                    <graphic>
                        <SVGPath content="M20,11 H7.83 l5.59,-5.59 L12,4 l-8,8 8,8 1.41,-1.41 L7.83,13 H20 V11 z"
                                 scaleX="0.75" scaleY="0.75" styleClass="gold-icon"/>
                    </graphic>
                </Button>

                <Button onAction="#onRulesClicked" styleClass="rules-button"
                        text="RULES &amp; REGULATIONS" contentDisplay="LEFT" graphicTextGap="10">
                    <graphic>
                        <SVGPath content="M14,2 H6 C4.9,2 4,2.9 4,4 v16 c0,1.1 0.9,2 2,2 h12 c1.1,0 2,-0.9 2,-2 V8 L14,2 z M16,18 H8 v-2 h8 V18 z M16,14 H8 v-2 h8 V14 z M13,9 V3.5 L18.5,9 H13 z"
                                 scaleX="0.8" scaleY="0.8" styleClass="gold-icon"/>
                    </graphic>
                </Button>

                <Region HBox.hgrow="ALWAYS"/>

                <VBox alignment="TOP_RIGHT">
                    <Label fx:id="clockLabel" text="10:44 AM" styleClass="clock-label"/>
                    <Label fx:id="dateLabel" text="Saturday, July 4" styleClass="date-label"/>
                </VBox>
            </HBox>

            <VBox alignment="CENTER" pickOnBounds="false" mouseTransparent="true">
                <Label text="Maplewood Grand" styleClass="header-hotel-name"/>
                <Label text="H O T E L" styleClass="header-hotel-sub"/>
            </VBox>
        </StackPane>

        <!-- ============ TITLE ============ -->
        <Label text="HOW MANY GUESTS?" styleClass="page-title">
            <VBox.margin>
                <Insets top="10"/>
            </VBox.margin>
        </Label>
        <Label text="Step 2 of 7" styleClass="step-label"/>

        <!-- ============ GUESTS CARD ============ -->
        <VBox styleClass="panel-card" prefWidth="420" maxWidth="420" spacing="14">
            <VBox.margin>
                <Insets top="10"/>
            </VBox.margin>
            <padding>
                <Insets top="18" right="18" bottom="18" left="18"/>
            </padding>

            <Label text="G U E S T S" styleClass="card-title" maxWidth="Infinity" alignment="CENTER"/>

            <HBox styleClass="stepper-row" alignment="CENTER_LEFT" spacing="12">
                <VBox>
                    <Label text="Adults" styleClass="row-label"/>
                    <Label text="(16+)" styleClass="row-sublabel"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="adultsCount" text="2" styleClass="count-label"/>
                <Button text="−" onAction="#adultsMinus" styleClass="stepper-btn"/>
                <Button text="+" onAction="#adultsPlus" styleClass="stepper-btn"/>
            </HBox>

            <HBox styleClass="stepper-row" alignment="CENTER_LEFT" spacing="12">
                <VBox>
                    <Label text="Children" styleClass="row-label"/>
                    <Label text="(0–15)" styleClass="row-sublabel"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="childrenCount" text="0" styleClass="count-label"/>
                <Button text="−" onAction="#childrenMinus" styleClass="stepper-btn"/>
                <Button text="+" onAction="#childrenPlus" styleClass="stepper-btn"/>
            </HBox>

            <Label fx:id="totalGuestsLabel" text="Total Guests: 2"
                   styleClass="card-footer" maxWidth="Infinity" alignment="CENTER"/>
        </VBox>

        <Region VBox.vgrow="ALWAYS"/>

        <!-- ============ BACK / NEXT ============ -->
        <HBox alignment="CENTER" maxWidth="936">
            <Button text="BACK" onAction="#onBack" styleClass="back-nav-button"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="NEXT: DATES" onAction="#onNext" styleClass="next-button"/>
        </HBox>

        <Label text="TOUCH TO BEGIN  •  24/7 SELF-SERVICE" styleClass="footer-label"/>
    </VBox>
</StackPane>
