<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<StackPane fx:id="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="ca.senecacollege.hotelreservation.hotelreservation.GuestFeedbackPage"
           prefWidth="1024" prefHeight="768"
           styleClass="root-pane" stylesheets="@kiosk.css">

    <ImageView fitWidth="1024" fitHeight="768" preserveRatio="false" opacity="0.3">
        <image>
            <Image url="@/lobby-background.jpg"/>
        </image>
    </ImageView>

    <Region styleClass="cream-overlay"/>

    <VBox alignment="TOP_CENTER" spacing="12">
        <padding>
            <Insets top="20" right="36" bottom="18" left="36"/>
        </padding>

        <!-- ============ HEADER ============ -->
        <StackPane>
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Button onAction="#onCancel" styleClass="rules-button"
                        text="BACK" contentDisplay="LEFT" graphicTextGap="8">
                    <graphic>
                        <SVGPath content="M20,11 H7.83 l5.59,-5.59 L12,4 l-8,8 8,8 1.41,-1.41 L7.83,13 H20 V11 z"
                                 scaleX="0.75" scaleY="0.75" styleClass="gold-icon"/>
                    </graphic>
                </Button>

                <Button onAction="#onRulesClicked" styleClass="rules-button"
                        text="RULES &amp; REGULATIONS" contentDisplay="LEFT" graphicTextGap="10">
                    <graphic>
                        <SVGPath content="M14,2 H6 C4.9,2 4,2.9 4,4 v16 c0,1.1 0.9,2 2,2 h12 c1.1,0 2,-0.9 2,-2 V8 L14,2 z M16,18 H8 v-2 h8 V18 z M16,14 H8 v-2 h8 V14 z M13,9 V3.5 L18.5,9 H13 z"
                                 scaleX="0.8" scaleY="0.8" styleClass="gold-icon"/>
                    </graphic>
                </Button>

                <Region HBox.hgrow="ALWAYS"/>

                <VBox alignment="TOP_RIGHT">
                    <Label fx:id="clockLabel" text="10:48 AM" styleClass="clock-label"/>
                    <Label fx:id="dateLabel" text="Saturday, July 4" styleClass="date-label"/>
                </VBox>
            </HBox>

            <VBox alignment="CENTER" pickOnBounds="false" mouseTransparent="true">
                <Label text="Maplewood Grand" styleClass="header-hotel-name"/>
                <Label text="H O T E L" styleClass="header-hotel-sub"/>
            </VBox>
        </StackPane>

        <!-- ============ TITLE ============ -->
        <Label text="LEAVE A REVIEW" styleClass="page-title"/>
        <Label text="We'd love to hear about your stay" styleClass="step-label"/>

        <!-- ============ FORM CARD ============ -->
        <VBox styleClass="panel-card" maxWidth="640" spacing="16">
            <padding>
                <Insets top="24" right="28" bottom="24" left="28"/>
            </padding>

            <VBox spacing="4">
                <HBox alignment="CENTER_LEFT" spacing="4">
                    <Label text="Guest Name" styleClass="form-label"/>
                    <Label text="*" styleClass="required-star"/>
                </HBox>
                <TextField fx:id="guestNameField" maxWidth="Infinity" styleClass="form-field"/>
            </VBox>

            <VBox spacing="4">
                <Label text="Reservation Number (optional)" styleClass="form-label"/>
                <TextField fx:id="resNoField" maxWidth="Infinity" styleClass="form-field"
                           promptText="e.g. MPL-4471"/>
            </VBox>

            <VBox spacing="6">
                <HBox alignment="CENTER_LEFT" spacing="4">
                    <Label text="Overall Rating" styleClass="form-label"/>
                    <Label text="*" styleClass="required-star"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label fx:id="star1" text="☆" styleClass="rating-picker-star" onMouseClicked="#rateStar1"/>
                    <Label fx:id="star2" text="☆" styleClass="rating-picker-star" onMouseClicked="#rateStar2"/>
                    <Label fx:id="star3" text="☆" styleClass="rating-picker-star" onMouseClicked="#rateStar3"/>
                    <Label fx:id="star4" text="☆" styleClass="rating-picker-star" onMouseClicked="#rateStar4"/>
                    <Label fx:id="star5" text="☆" styleClass="rating-picker-star" onMouseClicked="#rateStar5"/>
                </HBox>
            </VBox>

            <VBox spacing="4">
                <HBox alignment="CENTER_LEFT" spacing="4">
                    <Label text="Comment" styleClass="form-label"/>
                    <Label text="*" styleClass="required-star"/>
                </HBox>
                <TextArea fx:id="commentArea" prefRowCount="5" wrapText="true" styleClass="form-field"/>
            </VBox>
        </VBox>

        <!-- ============ CANCEL / SUBMIT ============ -->
        <HBox alignment="CENTER" maxWidth="640">
            <VBox.margin>
                <Insets top="6"/>
            </VBox.margin>
            <Button text="CANCEL" onAction="#onCancel" styleClass="back-nav-button"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="SUBMIT REVIEW" onAction="#onSubmit" styleClass="next-button"/>
        </HBox>
    </VBox>
</StackPane>
